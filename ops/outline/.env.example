# Outline Wiki — Environment Variables
# Copy this file to outline.env and fill in real values.

# Agent tooling (for scripts/outline/publish.mjs)
# OUTLINE_URL=http://localhost:3000
# OUTLINE_API_TOKEN=ol_api_...

SECRET_KEY=<generate with: openssl rand -hex 32>
UTILS_SECRET=<generate with: openssl rand -hex 32>

DATABASE_URL=postgres://outline:YOUR_DB_PASSWORD@postgres:5432/outline
DATABASE_URL_TEST=postgres://outline:YOUR_DB_PASSWORD@postgres:5432/outline-test
PGSSLMODE=disable
RATE_LIMITER_ENABLED=true
REDIS_URL=redis://redis:6379

URL=https://wiki.secretshop.ua
PORT=3000

# MinIO Storage
FILE_STORAGE=s3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=YOUR_MINIO_SECRET
AWS_REGION=us-east-1
AWS_S3_UPLOAD_BUCKET_URL=http://minio:9000
AWS_S3_UPLOAD_BUCKET_NAME=outline
AWS_S3_FORCE_PATH_STYLE=true

# Authentication (Authelia OIDC)
OIDC_CLIENT_ID=outline
OIDC_CLIENT_SECRET=YOUR_OIDC_SECRET
OIDC_AUTH_URI=https://auth.secretshop.ua/api/oidc/authorization
OIDC_TOKEN_URI=https://auth.secretshop.ua/api/oidc/token
OIDC_USERINFO_URI=https://auth.secretshop.ua/api/oidc/userinfo
OIDC_JWKS_URI=https://auth.secretshop.ua/api/oidc/jwks
OIDC_DISPLAY_NAME="Secretshop SSO"
OIDC_SCOPES="openid profile email"

FORCE_HTTPS=false
